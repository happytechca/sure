<%= render DS::Dialog.new(width: :lg) do |dialog| %>
  <% dialog.with_header(
       title: "Split transaction",
       subtitle: "Divide this transaction across multiple categories. Amounts must add up to the total."
     ) %>

  <% dialog.with_body do %>
    <div class="flex flex-col gap-5">

      <%# --- Table --- %>
      <div class="border border-primary rounded-lg overflow-hidden">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-container-inset border-b border-primary text-xs font-medium text-secondary">
              <th class="w-8 px-3 py-2 text-left font-medium">#</th>
              <th class="px-3 py-2 text-left font-medium border-l border-secondary">Category</th>
              <th class="px-3 py-2 text-left font-medium border-l border-secondary">Memo</th>
              <th class="px-3 py-2 text-left font-medium border-l border-secondary">Tags</th>
              <th class="w-28 px-3 py-2 text-right font-medium border-l border-secondary">Amount</th>
            </tr>
          </thead>
          <tbody>

            <%# Row 1 — pre-filled with the full transaction amount %>
            <tr class="border-b border-secondary">
              <td class="px-3 py-0 text-xs text-subdued align-middle">1</td>
              <td class="border-l border-secondary p-0">
                <select class="w-full px-3 py-2.5 bg-transparent text-sm text-subdued border-none focus:ring-0 focus:outline-none">
                  <option value="">Category...</option>
                  <% @categories.each do |cat| %>
                    <option value="<%= cat.id %>"><%= cat.name %></option>
                  <% end %>
                </select>
              </td>
              <td class="border-l border-secondary p-0">
                <input type="text" placeholder="Memo..." class="w-full px-3 py-2.5 bg-transparent text-sm border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
              <td class="border-l border-secondary p-0">
                <input type="text" placeholder="Tags..." class="w-full px-3 py-2.5 bg-transparent text-sm border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
              
              <td class="border-l border-secondary p-0">
                <input type="number" step="0.01" value="<%= @entry.amount.abs.to_d %>" class="w-full px-3 py-2.5 bg-transparent text-sm text-right border-none focus:ring-0 focus:outline-none" />
              </td>
            </tr>

            <%# Row 2 — empty %>
            <tr class="border-b border-secondary">
              <td class="px-3 py-0 text-xs text-subdued align-middle">2</td>
              <td class="border-l border-secondary p-0">
                <select class="w-full px-3 py-2.5 bg-transparent text-sm text-subdued border-none focus:ring-0 focus:outline-none">
                  <option value="">Category...</option>
                  <% @categories.each do |cat| %>
                    <option value="<%= cat.id %>"><%= cat.name %></option>
                  <% end %>
                </select>
              </td>
              <td class="border-l border-secondary p-0">
                <input type="text" placeholder="Memo..." class="w-full px-3 py-2.5 bg-transparent text-sm border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
              <td class="border-l border-secondary p-0">
                <input type="text" placeholder="Tags..." class="w-full px-3 py-2.5 bg-transparent text-sm border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
              
              <td class="border-l border-secondary p-0">
                <input type="number" step="0.01" placeholder="0.00" class="w-full px-3 py-2.5 bg-transparent text-sm text-right border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
            </tr>

            <%# Row 3 — empty %>
            <tr>
              <td class="px-3 py-0 text-xs text-subdued align-middle">3</td>
              <td class="border-l border-secondary p-0">
                <select class="w-full px-3 py-2.5 bg-transparent text-sm text-subdued border-none focus:ring-0 focus:outline-none">
                  <option value="">Category...</option>
                  <% @categories.each do |cat| %>
                    <option value="<%= cat.id %>"><%= cat.name %></option>
                  <% end %>
                </select>
              </td>
              <td class="border-l border-secondary p-0">
                <input type="text" placeholder="Memo..." class="w-full px-3 py-2.5 bg-transparent text-sm border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
              <td class="border-l border-secondary p-0">
                <input type="text" placeholder="Tags..." class="w-full px-3 py-2.5 bg-transparent text-sm border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
              
              <td class="border-l border-secondary p-0">
                <input type="number" step="0.01" placeholder="0.00" class="w-full px-3 py-2.5 bg-transparent text-sm text-right border-none focus:ring-0 focus:outline-none placeholder:text-subdued" />
              </td>
            </tr>

          </tbody>
        </table>
      </div>

      <%# --- Add line button --- %>
      <button type="button" class="flex items-center gap-1.5 text-sm text-secondary hover:text-primary w-fit">
        <%= icon("plus", size: "sm") %>
        Add line
      </button>

      <%# --- Totals summary --- %>
      <div class="border-t border-secondary pt-4 flex justify-end">
        <dl class="text-sm space-y-2 min-w-[220px]">
          <div class="flex justify-between gap-8">
            <dt class="text-secondary">Split total</dt>
            <dd class="font-medium text-primary"><%= number_to_currency(@entry.amount.abs.to_d) %></dd>
          </div>
          <div class="flex justify-between gap-8">
            <dt class="text-secondary">Remainder</dt>
            <dd class="font-medium text-success"><%= number_to_currency(0) %></dd>
          </div>
          <div class="flex justify-between gap-8 border-t border-secondary pt-2">
            <dt class="text-secondary">Transaction total</dt>
            <dd class="font-medium text-primary"><%= number_to_currency(@entry.amount.abs.to_d) %></dd>
          </div>
        </dl>
      </div>

    </div>
  <% end %>

  <% dialog.with_action(text: "Cancel", variant: "ghost", cancel_action: true) %>
  <% dialog.with_action(text: "Save split", variant: "primary") %>
<% end %>
